# AI-Memory — environment / setup values you provide per machine.
# Copy to ".env" (gitignored) and fill in. Nothing here is committed.

# Obsidian Local REST API + MCP plugin API key.
# Get it from: Obsidian > Settings > Community plugins > Local REST API > copy API key.
OBSIDIAN_API_KEY=your-obsidian-rest-api-key-here

# MCP endpoint exposed by the Local REST API plugin (plain HTTP avoids the self-signed cert).
OBSIDIAN_MCP_URL=http://127.0.0.1:27123/mcp/

# Absolute path to the vault on this machine (the single source of truth).
VAULT_PATH=C:\Users\you\AI-Memory
